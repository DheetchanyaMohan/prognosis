# Copy this file to .env and fill in real values for local development.
# .env is gitignored; .env.example is committed as documentation.

APP_NAME="ML Experiment Diagnosis & Decision Support System"
ENVIRONMENT=development
DEBUG=true

CORS_ALLOW_ORIGINS=["http://localhost:5173"]

DATABASE_URL=sqlite:///./data/db/experiments.db

# Required once the agent/LLM layer is implemented; unused by the current scaffold.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# app.llm service layer
LLM_PROVIDER=anthropic
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.0

LOG_LEVEL=INFO